{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/send_message.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/webhook",
      "dest": "api/webhook.py"
    },
    {
      "src": "/send",
      "dest": "api/send_message.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/webhook.py"
    }
  ],
  "crons": [
    {
      "path": "/send",
      "schedule": "* * * * *"
    }
  ]
}